# --- Invoice Ninja connection -------------------------------------------------
# Base URL of YOUR instance. Do NOT append /api/v1 (added automatically).
INVOICE_NINJA_URL=https://invoicing.example.ch

# Company API token: Settings > Account Management > Integrations > API Tokens
INVOICE_NINJA_TOKEN=your-company-token

# Optional. Only if you set an api_secret on the Invoice Ninja side.
# INVOICE_NINJA_SECRET=

# --- Safety -------------------------------------------------------------------
# Writes are OFF by default. Set to true to enable create/update/action tools.
INVOICE_NINJA_ALLOW_WRITES=false

# Caps rows returned to the model so list calls stay context-light.
INVOICE_NINJA_MAX_PER_PAGE=100
INVOICE_NINJA_TIMEOUT_MS=30000

# --- Remote (HTTP transport) only ---------------------------------------------
# PORT=8787
# HOST=127.0.0.1
# MCP_BEARER_TOKEN=generate-a-long-random-string
